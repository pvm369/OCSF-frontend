<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OCSF Log Mapper</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080c10;
    --surface: #0d1219;
    --border: #1a2535;
    --accent: #00d4ff;
    --accent2: #ff6b35;
    --green: #00ff88;
    --text: #c8d8e8;
    --muted: #4a6070;
    --bright: #f0f8ff;
    --card: #0f1820;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Radial glow */
  body::after {
    content: '';
    position: fixed;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(0,212,255,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(8,12,16,0.85);
    backdrop-filter: blur(16px);
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--bright);
    letter-spacing: -0.02em;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  /* ── HERO ── */
  .hero {
    padding: 140px 0 80px;
    position: relative;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(0,212,255,0.3);
    background: rgba(0,212,255,0.05);
    padding: 0.3rem 0.9rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.8rem;
    animation: fadeSlideUp 0.6s ease both;
  }
  .badge-dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--bright);
    margin-bottom: 1rem;
    animation: fadeSlideUp 0.6s 0.1s ease both;
  }
  h1 .accent { color: var(--accent); }
  h1 .accent2 { color: var(--accent2); }

  .hero-sub {
    font-size: 0.9rem;
    color: var(--muted);
    max-width: 560px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    animation: fadeSlideUp 0.6s 0.2s ease both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeSlideUp 0.6s 0.3s ease both;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-decoration: none;
    border: 1px solid;
    transition: all 0.2s;
    cursor: pointer;
    text-transform: uppercase;
  }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
    font-weight: 500;
  }
  .btn-primary:hover {
    background: transparent;
    color: var(--accent);
    box-shadow: 0 0 20px rgba(0,212,255,0.2);
  }
  .btn-ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--muted);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── PIPELINE DIAGRAM ── */
  .pipeline {
    margin: 80px 0;
    animation: fadeSlideUp 0.6s 0.4s ease both;
  }

  .pipeline-track {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    padding: 0.5rem 0;
    scrollbar-width: none;
  }
  .pipeline-track::-webkit-scrollbar { display: none; }

  .pipe-node {
    flex: 1;
    min-width: 150px;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1.2rem 1rem;
    text-align: center;
    position: relative;
    transition: border-color 0.3s, transform 0.3s;
  }
  .pipe-node:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    z-index: 2;
  }
  .pipe-node-icon {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    display: block;
  }
  .pipe-node-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    display: block;
    margin-bottom: 0.3rem;
  }
  .pipe-node-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--bright);
  }
  .pipe-arrow {
    color: var(--accent);
    font-size: 1.2rem;
    padding: 0 0.3rem;
    flex-shrink: 0;
    opacity: 0.6;
  }
  .pipe-node.highlight {
    border-color: rgba(0,212,255,0.4);
    background: rgba(0,212,255,0.03);
  }

  /* ── SECTION TITLES ── */
  .section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 0.6rem;
  }
  h2 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: -0.03em;
    color: var(--bright);
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  /* ── FEATURES GRID ── */
  .features {
    margin: 80px 0;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 2.5rem;
  }
  .feature-card {
    background: var(--card);
    padding: 2rem;
    transition: background 0.3s;
    position: relative;
    overflow: hidden;
  }
  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .feature-card:hover { background: rgba(0,212,255,0.03); }
  .feature-card:hover::before { opacity: 1; }
  .feature-icon {
    width: 36px; height: 36px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    margin-bottom: 1.2rem;
  }
  .feature-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--bright);
    margin-bottom: 0.6rem;
  }
  .feature-desc {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ── CODE BLOCK ── */
  .code-section {
    margin: 80px 0;
  }
  .code-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }
  .tab-btn {
    padding: 0.6rem 1.2rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    background: rgba(0,212,255,0.04);
  }
  .tab-btn:hover:not(.active) { color: var(--text); }

  .code-panel {
    display: none;
    background: var(--card);
    border: 1px solid var(--border);
    border-top: none;
  }
  .code-panel.active { display: block; }

  .code-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 1.2rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
  }
  .code-filename {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.06em;
  }
  .code-dots {
    display: flex;
    gap: 0.4rem;
  }
  .code-dots span {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--border);
  }
  .code-dots span:nth-child(1) { background: #ff5f57; }
  .code-dots span:nth-child(2) { background: #febc2e; }
  .code-dots span:nth-child(3) { background: #28c840; }

  pre {
    padding: 1.5rem;
    font-size: 0.78rem;
    line-height: 1.8;
    overflow-x: auto;
    color: var(--text);
  }
  .c-key { color: #ff6b35; }
  .c-str { color: #00ff88; }
  .c-val { color: var(--accent); }
  .c-cmt { color: var(--muted); opacity: 0.7; font-style: italic; }
  .c-num { color: #ffcc00; }

  /* ── SUPPORTED TABLE ── */
  .support-section { margin: 80px 0; }
  .support-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 2rem;
    font-size: 0.8rem;
  }
  .support-table th {
    text-align: left;
    padding: 0.8rem 1.2rem;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    font-weight: 400;
  }
  .support-table td {
    padding: 1rem 1.2rem;
    border-bottom: 1px solid rgba(26,37,53,0.5);
    color: var(--text);
    vertical-align: middle;
  }
  .support-table tr:hover td { background: rgba(0,212,255,0.02); }
  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    border: 1px solid rgba(0,212,255,0.25);
    color: var(--accent);
    background: rgba(0,212,255,0.04);
    margin: 0.15rem;
  }
  .tag-orange {
    border-color: rgba(255,107,53,0.3);
    color: var(--accent2);
    background: rgba(255,107,53,0.04);
  }
  .status-dot {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    margin-right: 0.5rem;
    box-shadow: 0 0 6px var(--green);
  }

  /* ── QUICKSTART ── */
  .quickstart { margin: 80px 0; }
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 2.5rem;
  }
  .step {
    background: var(--card);
    padding: 1.8rem;
  }
  .step-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: rgba(0,212,255,0.12);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .step-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--bright);
    margin-bottom: 0.5rem;
  }
  .step-code {
    font-size: 0.72rem;
    color: var(--green);
    background: rgba(0,255,136,0.04);
    border: 1px solid rgba(0,255,136,0.1);
    padding: 0.5rem 0.8rem;
    margin-top: 0.8rem;
    display: block;
  }

  /* ── EXTEND SECTION ── */
  .extend-section {
    margin: 80px 0;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .extend-section::after {
    content: 'NEW SOURCE';
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--green);
    border: 1px solid rgba(0,255,136,0.2);
    padding: 0.2rem 0.5rem;
  }
  .extend-list {
    list-style: none;
    margin-top: 1.5rem;
  }
  .extend-list li {
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--muted);
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .extend-list li:last-child { border-bottom: none; }
  .extend-list li .step-marker {
    color: var(--accent);
    flex-shrink: 0;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding-top: 0.05rem;
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    margin-top: 80px;
    padding: 2.5rem 0;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-brand {
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--bright);
  }
  .footer-brand span { color: var(--accent); }
  .footer-meta {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.06em;
  }
  .footer-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.3rem 0.7rem;
  }
  .footer-badge span { color: var(--green); }

  /* ── ANIMATIONS ── */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); }
  ::-webkit-scrollbar-thumb:hover { background: var(--muted); }

  @media (max-width: 640px) {
    h1 { font-size: 2.4rem; }
    .pipeline-track { gap: 0; }
    .pipe-arrow { display: none; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <div class="nav-logo">OCSF<span>.</span>mapper</div>
    <ul class="nav-links">
      <li><a href="#features">Features</a></li>
      <li><a href="#mapping">Mapping</a></li>
      <li><a href="#quickstart">Quickstart</a></li>
      <li><a href="https://github.com" target="_blank">GitHub ↗</a></li>
    </ul>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="badge"><span class="badge-dot"></span> PySpark · OCSF v1.1 · MIT License</div>
    <h1>Raw Logs →<br><span class="accent">Normalized</span><br><span class="accent2">Intelligence</span></h1>
    <p class="hero-sub">
      A declarative, schema-driven engine that maps raw security log events into
      OCSF-normalized format using YAML mapping files — zero code changes to add new sources.
    </p>
    <div class="hero-actions">
      <a href="#quickstart" class="btn btn-primary">↓ Get Started</a>
      <a href="https://github.com" class="btn btn-ghost">⬡ View on GitHub</a>
      <a href="#mapping" class="btn btn-ghost">⬡ How It Works</a>
    </div>
  </div>
</section>

<!-- PIPELINE DIAGRAM -->
<section style="padding-bottom:20px;">
  <div class="container">
    <div class="pipeline reveal">
      <p class="section-label">// data flow</p>
      <div class="pipeline-track">
        <div class="pipe-node highlight">
          <span class="pipe-node-icon">📄</span>
          <span class="pipe-node-label">Input</span>
          <span class="pipe-node-title">Raw JSON Logs</span>
        </div>
        <div class="pipe-arrow">→</div>
        <div class="pipe-node">
          <span class="pipe-node-icon">🔍</span>
          <span class="pipe-node-label">Step 1</span>
          <span class="pipe-node-title">Auto-Detect Source</span>
        </div>
        <div class="pipe-arrow">→</div>
        <div class="pipe-node">
          <span class="pipe-node-icon">📋</span>
          <span class="pipe-node-label">Step 2</span>
          <span class="pipe-node-title">Load YAML Rules</span>
        </div>
        <div class="pipe-arrow">→</div>
        <div class="pipe-node">
          <span class="pipe-node-icon">⚡</span>
          <span class="pipe-node-label">Step 3</span>
          <span class="pipe-node-title">Route + Resolve</span>
        </div>
        <div class="pipe-arrow">→</div>
        <div class="pipe-node highlight">
          <span class="pipe-node-icon">✅</span>
          <span class="pipe-node-label">Output</span>
          <span class="pipe-node-title">OCSF Event</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section id="features" class="features">
  <div class="container reveal">
    <p class="section-label">// capabilities</p>
    <h2>Built for Security<br>Engineers</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🎯</div>
        <div class="feature-title">Auto-Source Detection</div>
        <p class="feature-desc">Inspects required fields in each raw event to automatically identify the log source without manual tagging.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🗺️</div>
        <div class="feature-title">Declarative YAML Mappings</div>
        <p class="feature-desc">All routing, field resolution, and enum logic lives in YAML. No code changes needed to support a new log source.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔀</div>
        <div class="feature-title">Wildcard Enum Routing</div>
        <p class="feature-desc">Supports exact, wildcard (<code>Create*</code>), null-match, and fallback enum resolution for flexible event classification.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🧩</div>
        <div class="feature-title">Template Field Resolution</div>
        <p class="feature-desc">Use <code>{field.path}</code> syntax to bind raw event fields to OCSF schema paths, including deeply nested access.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⚡</div>
        <div class="feature-title">PySpark-Powered</div>
        <p class="feature-desc">Built on Apache Spark for scalable, distributed processing of high-volume security event streams.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📤</div>
        <div class="feature-title">JSON + YAML Output</div>
        <p class="feature-desc">Outputs normalized OCSF events as both JSON and YAML for downstream SIEM, data lake, and analytics pipelines.</p>
      </div>
    </div>
  </div>
</section>

<!-- CODE / MAPPING -->
<section id="mapping" class="code-section">
  <div class="container reveal">
    <p class="section-label">// how mapping works</p>
    <h2>Declarative Rules,<br>Zero Glue Code</h2>

    <div class="code-tabs">
      <button class="tab-btn active" onclick="showTab('input')">Raw Input</button>
      <button class="tab-btn" onclick="showTab('yaml')">YAML Mapping</button>
      <button class="tab-btn" onclick="showTab('output')">OCSF Output</button>
    </div>

    <div id="tab-input" class="code-panel active">
      <div class="code-header">
        <span class="code-filename">sample_logs/raw_logs.json</span>
        <div class="code-dots"><span></span><span></span><span></span></div>
      </div>
      <pre><span class="c-cmt">// Raw AWS CloudTrail event</span>
{
  <span class="c-key">"eventSource"</span>: <span class="c-str">"signin.amazonaws.com"</span>,
  <span class="c-key">"eventName"</span>:   <span class="c-str">"ConsoleLogin"</span>,
  <span class="c-key">"userIdentity"</span>: {
    <span class="c-key">"userName"</span>:    <span class="c-str">"alice"</span>,
    <span class="c-key">"principalId"</span>: <span class="c-str">"AIDA12345"</span>
  },
  <span class="c-key">"sourceIPAddress"</span>: <span class="c-str">"203.0.113.50"</span>,
  <span class="c-key">"responseElements"</span>: {
